---
import { PAGINATE_LIMITS } from "@/consts";
import PaginatedBlogLayout from "@/layouts/PaginatedBlogLayout.astro";
import { paginateArray } from "@/utils/paginate";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const all = await getCollection("blog");
    const totalPages = Math.ceil(all.length / PAGINATE_LIMITS.BLOG);
    return Array.from({ length: totalPages }).map((_, i) => ({
        params: { page: String(i + 1) },
    }));
}

const page = Number(Astro.params.page || 1);

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const paginated = paginateArray<"blog">(posts, page, PAGINATE_LIMITS.BLOG);
---

<PaginatedBlogLayout posts={paginated} currentPage={page} />
