---
import type { PaginatedCollection } from "@/types";
import { getBreadcrumbSchema } from "@/utils/jsonld";
import WebsiteLayout from "./WebsiteLayout.astro";
import PostCard from "@/components/blog/PostCard.astro";
import JsonLd from "@/components/layout/JsonLd.astro";
import Controls from "@/components/blog/Controls.astro";
import PaginationControls from "@/components/blog/PaginationControls.tsx";
import { PAGINATE_LIMITS } from "@/consts";

interface Props {
  category?: string;
  currentPage?: number;
  posts: PaginatedCollection<"blog">;
}

const {
  category,
  posts: { items: posts, total, totalPages },
  currentPage = 1,
} = Astro.props;

const breadcrumbs = [
  { name: "Inicio", item: "/" },
  { name: "Blog", item: "/blog" },
];

if (category) {
  breadcrumbs.push(
    { name: "Blog Categorías", item: "/blog/categoria" },
    { name: `Blog Categoría ${category}`, item: `/blog/categoria/${category}` },
  );

  if (currentPage > 1) {
    breadcrumbs.push({
      name: `Blog Categoría ${category} Pagina ${currentPage}`,
      item: `/blog/categoria/${category}/page/${currentPage}`,
    });
  }
} else {
  breadcrumbs.push({
    name: `Blog Pagina ${currentPage}`,
    item: `/blog/page/${currentPage}`,
  });
}

function renderCount(filteredTotal: number, visibleCount: number) {
  const word = filteredTotal === 1 ? "artículo" : "artículos";

  if (filteredTotal === 0) {
    return "No hay artículos que coincidan.";
  }

  const start = (currentPage - 1) * PAGINATE_LIMITS.BLOG + 1;
  const end = start + visibleCount - 1;

  if (filteredTotal === total) {
    return `Mostrando ${start} - ${end} de ${total} ${word}`;
  } else {
    return `Mostrando ${start} - ${end} de ${filteredTotal} ${word} (${total} totales)`;
  }
}

const breadcrumbSchema = getBreadcrumbSchema(breadcrumbs);
---

<WebsiteLayout seoProps={{ title: "Blog de Desarrollo Web" }}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16">
    <header class="mb-12">
      <h1 class="text-4xl lg:text-5xl font-extrabold mb-6 tracking-tight">
        Blog de Desarrollo
      </h1>
      <p
        class="text-lg sm:text-xl text-slate-600 dark:text-slate-500 max-w-3xl"
      >
        Tutoriales detallados, comparativas de herramientas y experiencias
        reales escalando aplicaciones web.
      </p>
    </header>

    <Controls selectedCategory={category} />

    {/* Posts Count info */}
    <div class="mb-8 text-sm text-slate-500 font-medium">
      <div id="postsCountInfo">
        {renderCount(total, posts.length)}
      </div>
    </div>

    {/* Posts Grid */}
    <div
      id="posts"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10"
    >
      {posts.map((post) => <PostCard post={post} />)}

      <div
        id="emptyStatePosts"
        class="col-span-full text-center py-20 px-8 bg-slate-50 dark:bg-transparent rounded-[3rem] border-2 border-dashed border-slate-200 hidden dark:border-slate-800"
      >
        <p class="text-slate-500 text-lg">
          No encontramos artículos que coincidan con tu búsqueda.
        </p>
        <button
          id="clearEmptySearch"
          class="mt-4 text-indigo-600 font-bold hover:underline transition-all"
          >Ver todos los posts</button
        >
      </div>
    </div>

    <div class="mt-16 flex justify-center items-center gap-4">
      <PaginationControls
        currentPage={currentPage}
        totalPages={totalPages}
        currentCategory={category}
        client:load
      />
    </div>
  </div>

  <JsonLd schema={breadcrumbSchema} />
</WebsiteLayout>
